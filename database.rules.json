{
  "rules": {
    "sensors": {
      "current": {
        ".read": true,
        ".write": true
      }
    },
    "controls": {
      "servo_angle": {
        ".read": true,
        ".write": true
      },
      "harvestLid": {
        ".read": true,
        ".write": true
      },
      "harvest_lid": {
        ".read": true,
        ".write": true
      }
    },
    "maintenance": {
      ".read": true,
      ".write": true
    },
    "settings": {
      ".read": true,
      ".write": true
    },
    "logs": {
      ".read": true,
      ".write": true
    },
    "analytics": {
      ".read": true,
      ".write": true,
      "minutes": {
        "$deviceId": {
          ".read": true,
          ".write": true,
          ".indexOn": ["timestamp"]
        }
      }
    }
  }
}
